CREATE TABLE chat_messages (
  id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
  session_id TEXT NOT NULL,
  role TEXT NOT NULL,
  content TEXT NOT NULL,
  created_at INTEGER NOT NULL
);

selectBySession:
SELECT id, session_id, role, content, created_at
FROM chat_messages
WHERE session_id = ?
ORDER BY created_at ASC, id ASC;

insertMessage:
INSERT INTO chat_messages(session_id, role, content, created_at)
VALUES (?, ?, ?, ?);

deleteBySession:
DELETE FROM chat_messages
WHERE session_id = ?;

deleteById:
DELETE FROM chat_messages
WHERE id = ?;

createUsageTable:
CREATE TABLE IF NOT EXISTS session_usage_totals (
  session_id TEXT NOT NULL PRIMARY KEY,
  prompt_tokens INTEGER NOT NULL,
  completion_tokens INTEGER NOT NULL,
  total_tokens INTEGER NOT NULL
);

selectUsageBySession:
SELECT session_id, prompt_tokens, completion_tokens, total_tokens
FROM session_usage_totals
WHERE session_id = ?;

upsertUsageBySession:
INSERT OR REPLACE INTO session_usage_totals(session_id, prompt_tokens, completion_tokens, total_tokens)
VALUES (?, ?, ?, ?)
;

deleteUsageBySession:
DELETE FROM session_usage_totals
WHERE session_id = ?;
